// Inhalt - content layer schema.
//
// Two halves:
//   - The content model: Project (the tenant boundary), ApiKey, ContentType,
//     Entry. Writes are typed against ContentType.fields (see app/lib/fields.ts).
//   - Authentication: User, Session, Account, Verification are owned by
//     better-auth (app/lib/auth.ts). Each User owns their Project(s); the bearer
//     ApiKeys gate the MCP server (app/lib/bearer-auth.ts).

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A content space and the tenant boundary. Owns content types, entries, and
/// API keys. Ownership / membership (via better-auth) is connected later.
model Project {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // used in the read API path
  ownerId   String? // the User who owns this workspace; null for the seed default
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  apiKeys      ApiKey[]
  contentTypes ContentType[]

  @@index([ownerId])
}

/// Bearer token used by MCP clients. The plaintext secret is shown exactly once
/// at creation and never stored; we keep a one-way hash plus a display prefix.
/// `scopes` restricts which content types and actions the token can reach.
model ApiKey {
  id         String    @id @default(cuid())
  projectId  String
  name       String // "Production", "Claude Desktop"
  prefix     String // shown in the UI, e.g. inh_live_ab12
  hash       String    @unique // sha-256 of the full secret
  scopes     Json // { contentTypes: ["post", "*"], actions: ["read", "patch", ...] }
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// A typed content model. `fields` holds the field definitions that both
/// describe the MCP tools to a client and validate every write.
/// Field shape: [{ key, type, required, ...type-specific options }].
model ContentType {
  id        String   @id @default(cuid())
  projectId String
  key       String // machine name, e.g. "post"
  name      String // display name, e.g. "Blog Post"
  fields    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entries Entry[]

  @@unique([projectId, key])
}

/// A content item. Carries a working `draft` copy and the last `published`
/// copy. Publishing copies draft -> published and stamps publishedAt. There is
/// no version history: the model stays at drafts -> save -> publish.
model Entry {
  id            String      @id @default(cuid())
  contentTypeId String
  slug          String // human / url id, unique within its content type
  status        EntryStatus @default(DRAFT)
  draft         Json // working values, always present
  published     Json? // last published values, null until first publish
  publishedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  contentType ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)

  @@unique([contentTypeId, slug])
  @@index([contentTypeId, status])
}

enum EntryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// --- Authentication (better-auth) -------------------------------------------
// These four models are managed by better-auth (app/lib/auth.ts). Field names
// and table mappings match what the library expects; do not rename them. The
// only local addition is the User -> Project ownership relation.

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  projects      Project[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
