# Copy to .env and fill in. The real .env is gitignored.

# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/inhalt?schema=public"

# Secret used by better-auth to sign sessions. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-a-32-byte-random-string"

# Base URL better-auth uses for callbacks and cookies. Set to your app's origin
# (no trailing slash). In production this is https://app.inhalt.tech.
BETTER_AUTH_URL="http://localhost:3000"

# MCP endpoint shown on the dashboard's Connection tab and in the generated
# mcp.json snippet. NEXT_PUBLIC_ so it is inlined into the client bundle.
NEXT_PUBLIC_MCP_ENDPOINT="https://app.inhalt.tech/mcp"
